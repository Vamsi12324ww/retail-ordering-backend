generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id Int @id @default(autoincrement())

  sku         String  @unique
  name        String
  description String?

  price Float
  stock Int   @default(0)

  imageUrl String?

  category    String?
  brand       String?
  distributor String?

  casePack Int?
  unit     String?
  barcode  String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
